# Required: MongoDB connection used by Payload
DATABASE_URI="mongodb://127.0.0.1/nanotest"

# Required: Browser-facing base URL for preview links, admin integrations, and asset URLs
NEXT_PUBLIC_SERVER_URL="http://localhost:3301"

# Optional: Server-side self-call URL for revalidation and internal callbacks
# Useful when the app cannot reach itself through the public domain in production
# INTERNAL_SERVER_URL="http://127.0.0.1:3000"

# Required: Secret used by Payload for JWT signing and other secure operations
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET="replace-with-a-long-random-secret"

# Required for the contact form email endpoint
SMTP_EMAIL_HOST="mail.example.com"
SMTP_EMAIL_PORT="465"
SMTP_EMAIL_USER="user@example.com"
SMTP_EMAIL_PASS="replace-with-smtp-password"

# Required for the contact form captcha check
# NEXT_PUBLIC_* variables are exposed to the browser bundle
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="replace-with-public-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="replace-with-private-recaptcha-secret"

# Optional: Production runtime port
# In local development `pnpm dev` hardcodes port 3301.
# On Mittwald, PORT is provided by the platform and must not be hardcoded there.
# PORT="3000"

# Optional: Only used by `pnpm db:sync`
# DATABASE_URI_PROD="mongodb://user:pass@prod-host:27017/nanotest"
# DATABASE_URI_DEV="mongodb://127.0.0.1/nanotest"
